<Window x:Class="Brumak_Client.Forms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Brumak"
        Height="600" Width="1000"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#111"
        xmlns:Legal="clr-namespace:Brumak_Client.Forms.Legal"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Forms/Style/MainStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">

            <Button Content="—"
                    Style="{StaticResource WindowButton}"
                    Click="Minimize_Click"/>

            <Button Content="X"
                    Style="{StaticResource WindowButton}"
                    Click="Close_Click"/>
        </StackPanel>

        <Grid Grid.Column="0" Background="#F5F5F5">

            <StackPanel Margin="30">

                <TextBlock Text="BRUMAK"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,20">

                    <Button x:Name="BtnLogin"
                            Content="Iniciar sesión"
                            Style="{StaticResource TabActive}"
                            Click="ShowLogin"/>

                    <Button x:Name="BtnRegister"
                            Content="Registro"
                            Style="{StaticResource TabInactive}"
                            Click="ShowRegister"/>

                </StackPanel>

                <Grid>
                    <StackPanel x:Name="LoginPanel">

                        <TextBlock Text="NOMBRE DE USUARIO" FontSize="11" Foreground="#666"/>
                        <TextBox 
                            x:Name="LAUsername" 
                            MaxLength="16"
                            Style="{StaticResource TextBox}"/>

                        <TextBlock Text="CONTRASEÑA" FontSize="11" Foreground="#666" Margin="0,15,0,0"/>
                        <PasswordBox 
                            x:Name="LAPassword" 
                            MaxLength="20"
                            Style="{StaticResource PasswordBox}"/>

                        <CheckBox x:Name="LAKeepSessionCb" Content="Mantener sesión iniciada"
                                  Foreground="#666"
                                  FontSize="12"
                                  Margin="0,10"/>

                        <Button Content="Iniciar sesión"
                                Click="LoginAccount_Click"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,10"/>

                        <TextBlock x:Name="LAAccountLoginResult"
                            Visibility="Hidden"
                            Text="(...)" FontSize="11" Foreground="#666"/>

                        <TextBlock Margin="0,15,0,0">
                            <Hyperlink>¿No puedes iniciar sesión?</Hyperlink>
                        </TextBlock>

                    </StackPanel>
                    <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">

                        <TextBlock Text="NOMBRE DE USUARIO" FontSize="11" Foreground="#666"/>
                        <TextBox 
                            x:Name="CAUsername" 
                            MaxLength="16"
                            Style="{StaticResource TextBox}"/>

                        <TextBlock Text="APODO (VISIBLE A LOS DEMÁS)" FontSize="11" Foreground="#666" Margin="0,15,0,0"/>
                        <TextBox 
                            x:Name="CANickname" 
                            MaxLength="16"
                            Style="{StaticResource TextBox}"/>

                        <TextBlock Text="EMAIL" FontSize="11" Foreground="#666" Margin="0,15,0,0"/>
                        <TextBox 
                            x:Name="CAEmail" 
                            MaxLength="100"
                            Style="{StaticResource TextBox}"/>

                        <TextBlock Text="CONTRASEÑA" FontSize="11" Foreground="#666" Margin="0,15,0,0"/>
                        <PasswordBox 
                            x:Name="CAPassword" 
                            MaxLength="20"
                            Style="{StaticResource PasswordBox}"/>

                        <CheckBox
                          x:Name="CATermsAndConditionsCb"
                          FontSize="12"
                          Margin="0,10">
                            <Hyperlink Click="ShowTermsAndConditions">He leído y acepto los términos y condiciones</Hyperlink>
                        </CheckBox>

                        <Button Content="Crear cuenta"
                                Style="{StaticResource PrimaryButton}"
                                Click="CreateAccount_Click"
                                Margin="0,20"/>

                        <TextBlock x:Name="CAAccountCreationResultTb"
                            Visibility="Hidden"
                            Text="(...)" FontSize="11" Foreground="#666"/>

                    </StackPanel>
                </Grid>

            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Border 
                Background="#A5000000"          
                CornerRadius="6"
                Padding="12,8"
                Margin="0,10,10,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Panel.ZIndex="1">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusEllipse" Width="10" Height="10" Fill="#FFFF0005" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PingLabel"
                        Text="En estos momentos el servidor está sin conexión (...)" 
                        FontSize="12" 
                        Foreground="White" 
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <Legal:MainTermsAndConditions
                x:Name="TermsUserControl" 
                Visibility="Collapsed" 
                Panel.ZIndex="1"/>
            <StackPanel Panel.ZIndex="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0">
                <Button Content="—"
                        Style="{StaticResource WindowButton}"
                        Click="Minimize_Click"/>
                <Button Content="X"
                        Style="{StaticResource WindowButton}"
                        Click="Close_Click"/>
            </StackPanel>
            <Image 
                Source="/Assets/Login/SplashArt.jpg"
                Stretch="None"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
            <Rectangle Fill="#66000000"/>
        </Grid>
    </Grid>
</Window>