<Window x:Class="Brumak_Client.Forms.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Brumak"
        Height="600" Width="1000"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#111"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="TextBox" TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="PasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#D13639"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D41111"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B20E0E"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabActive" TargetType="Button">
            <Setter Property="Foreground" Value="#111"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="TabInactive" TargetType="Button">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4"
                    SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  RecognizesAccessKey="True"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D41111"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B20E0E"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">

            <Button Content="—"
                    Style="{StaticResource WindowButton}"
                    Click="Minimize_Click"/>

            <Button Content="X"
                    Style="{StaticResource WindowButton}"
                    Click="Close_Click"/>
        </StackPanel>

        <Grid Grid.Column="0" Background="#F5F5F5">

            <StackPanel Margin="30">

                <TextBlock Text="BRUMAK"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,20">

                    <Button x:Name="BtnLogin"
                            Content="Iniciar sesión"
                            Style="{StaticResource TabActive}"
                            Click="ShowLogin"/>

                    <Button x:Name="BtnRegister"
                            Content="Registro"
                            Style="{StaticResource TabInactive}"
                            Click="ShowRegister"/>

                </StackPanel>

                <Grid>
                    <StackPanel x:Name="LoginPanel">

                        <TextBlock Text="NOMBRE DE USUARIO" FontSize="11" Foreground="#666"/>
                        <TextBox Style="{StaticResource TextBox}"/>

                        <TextBlock Text="CONTRASEÑA" FontSize="11" Foreground="#666" Margin="0,15,0,0"/>
                        <PasswordBox Style="{StaticResource PasswordBox}"/>

                        <CheckBox Content="Mantener sesión iniciada"
                                  FontSize="12"
                                  Margin="0,10"/>

                        <Button Content="Iniciar sesión"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,10"/>

                        <TextBlock Text="¿No puedes iniciar sesión?"
                                   Foreground="#666"
                                   FontSize="12"
                                   Margin="0,20,0,0"
                                   Cursor="Hand"/>

                    </StackPanel>

                    <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">

                        <TextBlock Text="USUARIO" FontSize="11" Foreground="#666"/>
                        <TextBox Style="{StaticResource TextBox}"/>

                        <TextBlock Text="EMAIL" FontSize="11" Foreground="#666" Margin="0,15,0,0"/>
                        <TextBox Style="{StaticResource TextBox}"/>

                        <TextBlock Text="CONTRASEÑA" FontSize="11" Foreground="#666" Margin="0,15,0,0"/>
                        <PasswordBox Style="{StaticResource PasswordBox}"/>

                        <Button Content="Crear cuenta"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,20"/>

                    </StackPanel>

                </Grid>

            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Border 
                Background="#A5000000"          
                CornerRadius="6"
                Padding="12,8"
                Margin="0,10,10,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Panel.ZIndex="1">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusEllipse" Width="10" Height="10" Fill="#FFFF0005" VerticalAlignment="Center"/>
                    <TextBlock x:Name="PingLabel"
                        Text="En estos momentos el servidor está sin conexión (...)" 
                        FontSize="12" 
                        Foreground="White" 
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"/>    
                </StackPanel>
            </Border>
            <StackPanel Panel.ZIndex="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0">
                <Button Content="—"
                        Style="{StaticResource WindowButton}"
                        Click="Minimize_Click"/>
                <Button Content="X"
                        Style="{StaticResource WindowButton}"
                        Click="Close_Click"/>
            </StackPanel>
            <Image 
                Source="/Assets/Login/SplashArt.jpg"
                Stretch="None"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
            <Rectangle Fill="#66000000"/>
        </Grid>

    </Grid>
</Window>